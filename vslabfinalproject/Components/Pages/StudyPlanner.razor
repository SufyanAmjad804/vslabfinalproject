@page "/study-planner"
@attribute [Authorize]
@inject ISchoolService SchoolService
@inject AuthenticationStateProvider AuthStateProvider

<div class="page-title">
    <div>
        <h2>My Study Planner</h2>
        <p class="text-muted">Create, update, complete, search and delete your own study tasks.</p>
    </div>
</div>

<AlertBox Message="@message" Type="@messageType" />

<div class="grid grid-4 mb-3">
    <StatCard Title="Total Tasks" Value="@tasks.Count.ToString()" Description="Your planned work" Icon="🗂️" AccentClass="primary" />
    <StatCard Title="Pending" Value="@pendingCount.ToString()" Description="Still remaining" Icon="⏳" AccentClass="warning" />
    <StatCard Title="Completed" Value="@completedCount.ToString()" Description="Finished tasks" Icon="✅" AccentClass="success" />
    <StatCard Title="High Priority" Value="@highPriorityCount.ToString()" Description="Needs attention" Icon="🔥" AccentClass="danger" />
</div>

<div class="grid grid-2">
    <div class="data-card">
        <div class="card-heading">
            <div>
                <h3>@(taskForm.Id == 0 ? "Add Study Task" : "Edit Study Task")</h3>
                <p>Use this student-side CRUD form to manage your own planner.</p>
            </div>
        </div>

        <EditForm Model="@taskForm" OnValidSubmit="SaveTaskAsync">
            <DataAnnotationsValidator />
            <div class="form-grid">
                <div>
                    <label class="form-label">Task Title</label>
                    <InputText class="form-control" @bind-Value="taskForm.Title" />
                    <ValidationMessage For="@(() => taskForm.Title)" />
                </div>
                <div>
                    <label class="form-label">Due Date</label>
                    <InputDate class="form-control" @bind-Value="taskForm.DueDate" />
                </div>
                <div>
                    <label class="form-label">Priority</label>
                    <InputSelect class="form-select" @bind-Value="taskForm.Priority">
                        <option>Low</option>
                        <option>Medium</option>
                        <option>High</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => taskForm.Priority)" />
                </div>
                <div>
                    <label class="form-label">Status</label>
                    <InputSelect class="form-select" @bind-Value="taskForm.Status">
                        <option>Pending</option>
                        <option>In Progress</option>
                        <option>Completed</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => taskForm.Status)" />
                </div>
                <div class="form-grid-full">
                    <label class="form-label">Description</label>
                    <InputTextArea class="form-control" @bind-Value="taskForm.Description" />
                    <ValidationMessage For="@(() => taskForm.Description)" />
                </div>
            </div>
            <div class="toolbar mt-3">
                <button class="btn btn-primary" type="submit">@(taskForm.Id == 0 ? "Add Task" : "Update Task")</button>
                @if (taskForm.Id != 0)
                {
                    <button class="btn btn-outline-secondary" type="button" @onclick="ResetForm">Cancel Edit</button>
                }
            </div>
        </EditForm>
    </div>

    <div class="data-card">
        <div class="card-heading">
            <div>
                <h3>Planner Filters</h3>
                <p>Search and filter tasks by title, priority or status.</p>
            </div>
        </div>

        <div class="form-grid">
            <div>
                <label class="form-label">Search</label>
                <InputText class="form-control" placeholder="Search tasks" @bind-Value="searchTerm" />
            </div>
            <div>
                <label class="form-label">Status Filter</label>
                <InputSelect class="form-select" @bind-Value="statusFilter">
                    <option>All</option>
                    <option>Pending</option>
                    <option>In Progress</option>
                    <option>Completed</option>
                </InputSelect>
            </div>
        </div>
        <div class="toolbar mt-3">
            <button class="btn btn-primary" @onclick="LoadTasksAsync">Apply Filter</button>
            <button class="btn btn-outline-secondary" @onclick="ClearFiltersAsync">Clear</button>
        </div>

        <ul class="list-clean mt-3">
            <li>
                <div>
                    <div class="item-title">CRUD Requirement Covered</div>
                    <div class="item-text">This page includes create, read, update, delete, search, filter and status update.</div>
                </div>
                <div class="item-meta">Student-only</div>
            </li>
        </ul>
    </div>
</div>

<div class="data-card mt-3">
    <div class="card-heading">
        <div>
            <h3>My Tasks</h3>
            <p>Tasks are stored in SQLite and linked to the logged-in student account.</p>
        </div>
    </div>

    @if (tasks.Count == 0)
    {
        <div class="empty-state">No study tasks found. Add your first task from the form above.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Due Date</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in tasks)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.Description</td>
                            <td>@item.DueDate.ToString("dd MMM yyyy")</td>
                            <td><span class="@GetPriorityClass(item.Priority)">@item.Priority</span></td>
                            <td><span class="@GetStatusClass(item.Status)">@item.Status</span></td>
                            <td>
                                <div class="toolbar compact-actions">
                                    <button class="btn btn-primary btn-sm" @onclick="() => EditTask(item)">Edit</button>
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => ToggleCompleteAsync(item.Id)">@(item.IsCompleted ? "Reopen" : "Complete")</button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteTaskAsync(item.Id)">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
@code {
    private Student? student;
    private StudyTask taskForm = NewTask();
    private List<StudyTask> tasks = new();
    private string searchTerm = string.Empty;
    private string statusFilter = "All";
    private string message = string.Empty;
    private string messageType = "success";
    private int pendingCount;
    private int completedCount;
    private int highPriorityCount;

    protected override async Task OnInitializedAsync()
    {
        student = await GetCurrentStudentAsync();
        await LoadTasksAsync();
    }

    private async Task SaveTaskAsync()
    {
        if (student is null)
        {
            message = "Student account was not found.";
            messageType = "danger";
            return;
        }

        var isNewTask = taskForm.Id == 0;
        taskForm.StudentId = student.Id;
        taskForm.IsCompleted = taskForm.Status == "Completed";
        await SchoolService.SaveStudyTaskAsync(taskForm);
        message = isNewTask ? "Study task added successfully." : "Study task updated successfully.";
        messageType = "success";
        ResetForm();
        await LoadTasksAsync();
    }

    private async Task LoadTasksAsync()
    {
        if (student is null)
        {
            tasks = new();
            return;
        }

        tasks = await SchoolService.GetStudyTasksAsync(student.Id, searchTerm, statusFilter);
        pendingCount = tasks.Count(item => item.Status != "Completed");
        completedCount = tasks.Count(item => item.Status == "Completed");
        highPriorityCount = tasks.Count(item => item.Priority == "High" && item.Status != "Completed");
    }

    private void EditTask(StudyTask task)
    {
        taskForm = new StudyTask
        {
            Id = task.Id,
            StudentId = task.StudentId,
            Title = task.Title,
            Description = task.Description,
            DueDate = task.DueDate,
            Priority = task.Priority,
            Status = task.Status,
            IsCompleted = task.IsCompleted,
            CreatedAt = task.CreatedAt,
            UpdatedAt = task.UpdatedAt
        };
        message = "Editing selected task.";
        messageType = "success";
    }

    private async Task ToggleCompleteAsync(int id)
    {
        await SchoolService.ToggleStudyTaskCompletionAsync(id);
        message = "Task status updated.";
        messageType = "success";
        await LoadTasksAsync();
    }

    private async Task DeleteTaskAsync(int id)
    {
        await SchoolService.DeleteStudyTaskAsync(id);
        message = "Study task deleted.";
        messageType = "success";
        await LoadTasksAsync();
    }

    private async Task ClearFiltersAsync()
    {
        searchTerm = string.Empty;
        statusFilter = "All";
        await LoadTasksAsync();
    }

    private void ResetForm()
    {
        taskForm = NewTask();
    }

    private static StudyTask NewTask() => new()
    {
        Title = "Revise today's lecture",
        Description = "Write the topic or task details here.",
        DueDate = DateTime.Today.AddDays(1),
        Priority = "Medium",
        Status = "Pending"
    };

    private static string GetPriorityClass(string priority)
    {
        return priority switch
        {
            "High" => "status-pill danger",
            "Medium" => "status-pill warning",
            _ => "status-pill success"
        };
    }

    private static string GetStatusClass(string status)
    {
        return status switch
        {
            "Completed" => "status-pill success",
            "In Progress" => "status-pill warning",
            _ => "status-pill info"
        };
    }

    private async Task<Student?> GetCurrentStudentAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = state.User.Identity?.Name ?? "irtaza@studentdash.local";
        var students = await SchoolService.GetStudentsAsync(email);
        return students.FirstOrDefault(item => item.Email.Equals(email, StringComparison.OrdinalIgnoreCase))
            ?? students.FirstOrDefault()
            ?? (await SchoolService.GetStudentsAsync()).FirstOrDefault();
    }
}
