@inject DashboardAuthStateProvider AuthProvider   // Commit 1: Added authentication provider
@inject NavigationManager Navigation              // Commit 1: Added navigation manager
<aside class="sidebar">   <!-- Commit 2: Created sidebar layout -->

    <!-- Commit 2: Added brand/logo section -->
    <div class="brand">
        <div class="brand-icon">🎓</div>
        <div>
            <strong>Student Dashboard</strong>
            <small>Student account</small>
        </div>
    </div>
    <!-- Commit 3: Added authorization handling -->
    <AuthorizeView Context="authState">

        <!-- Commit 3: Authorized user section -->
        <Authorized>

            <!-- Commit 4: Added logged-in student info -->
            <div class="sidebar-user simple-user">
                <div class="avatar-badge">
                    @GetInitials(authState.User.Identity?.Name)
                </div>

                <div>
                    <strong>
                        @GetStudentName(authState.User.Identity?.Name)
                    </strong>
                    <small>Student account</small>
                </div>
            </div>
 <!-- Commit 5: Added navigation menu -->
            <nav class="nav-list mt-3">

                <NavLink href="/" Match="NavLinkMatch.All">
                    <span class="nav-icon">🏠</span> Dashboard
                </NavLink>

                <NavLink href="/profile">
                    <span class="nav-icon">👤</span> My Profile
                </NavLink>

                <NavLink href="/courses">
                    <span class="nav-icon">📚</span> My Courses
                </NavLink>

                <NavLink href="/attendance">
                    <span class="nav-icon">✅</span> My Attendance
                </NavLink>

                <NavLink href="/grades">
                    <span class="nav-icon">📝</span> My Grades
                </NavLink>

                <NavLink href="/assignments">
                    <span class="nav-icon">📌</span> Assignments
                </NavLink>

                <NavLink href="/study-planner">
                    <span class="nav-icon">🗂️</span> Study Planner
                </NavLink>

                <NavLink href="/fees">
                    <span class="nav-icon">💳</span> Fees
                </NavLink>

                <NavLink href="/notifications">
                    <span class="nav-icon">🔔</span> Notifications
                </NavLink>

                <NavLink href="/events">
                    <span class="nav-icon">🗓️</span> Events
                </NavLink>

                <NavLink href="/support">
                    <span class="nav-icon">🛟</span> Support
                </NavLink>

            </nav>

            <!-- Commit 6: Added logout button -->
            <button class="btn btn-outline-light w-100 mt-3 logout-btn"
                    @onclick="LogoutAsync">
                Logout
            </button>

        
    </AuthorizeView>

</aside>

